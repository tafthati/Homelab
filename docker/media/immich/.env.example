# ============================================
#   IMMICH — Environment Variables
#   Docs: https://docs.immich.app/install/environment-variables
# ============================================

# Percorso locale per i file caricati da Immich
UPLOAD_LOCATION=/home/YOUR_USERNAME/docker/immich/data

# Percorso locale per i dati del database PostgreSQL
DB_DATA_LOCATION=/home/YOUR_USERNAME/docker/immich/postgres

# Timezone del server
TZ=Europe/Rome

# Versione Immich da usare (release = ultima stabile)
IMMICH_VERSION=release

# --- Credenziali PostgreSQL ---
# Genera una password sicura con: openssl rand -base64 24
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
DB_PASSWORD=your_secure_password_here

# Machine learning per riconoscimento facciale e oggetti
# false = disabilitato (consigliato su hardware con poca RAM)
MACHINE_LEARNING_ENABLED=false
