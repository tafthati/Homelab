# ============================================
#   OPENSPEEDTEST — Environment Variables
# ============================================

# Porta HTTP su cui esporre il servizio (default: 3000)
OPENSPEEDTEST_PORT_HTTP=2080

# Porta HTTPS su cui esporre il servizio (default: 3001)
OPENSPEEDTEST_PORT_HTTPS=2443

# Abilita Let's Encrypt per certificato SSL automatico
# true = abilita SSL con certificato pubblico (richiede DOMAIN_NAME e USER_EMAIL)
# false = HTTP semplice, nessun certificato (consigliato per uso locale/LAN)
ENABLE_LETSENCRYPT=false

# Dominio pubblico per Let's Encrypt (necessario solo se ENABLE_LETSENCRYPT=true)
# Esempio: speedtest.tuodominio.com
DOMAIN_NAME=your.domain.com

# Email per la registrazione Let's Encrypt (necessario solo se ENABLE_LETSENCRYPT=true)
USER_EMAIL=your@email.com

# Timezone del server
TZ=[Zona/Città]
