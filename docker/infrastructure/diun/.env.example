# ============================================
#   DIUN — Environment Variables
#   Docs: https://crazymax.dev/diun/config
# ============================================

# --- Notifiche Telegram ---
# Token del bot Telegram (da @BotFather)
# ⚠️  NON committare mai questo valore su Git
DIUN_TELEGRAM_TOKEN=your_telegram_bot_token_here

# Chat ID del gruppo/canale Telegram
# Formato per topic specifico: -100XXXXXXXXXX:TOPIC_ID
# ⚠️  NON committare mai questo valore su Git
DIUN_TELEGRAM_CHATID=-100XXXXXXXXXX:2

# --- Monitoraggio ---
# Numero di worker paralleli per il controllo aggiornamenti
DIUN_WATCH_WORKERS=20

# Schedule controllo aggiornamenti (cron) — default: ogni giorno alle 17:00
DIUN_WATCH_SCHEDULE=0 17 * * *

# --- Configurazione server ---
TZ=Europe/Rome
