# ============================================
#   HOMEPAGE — Environment Variables
#   Docs: https://gethomepage.dev/configs/settings/
# ============================================

# --- Sistema ---
PUID=1000
PGID=1000

# --- Porte esposte ---
HOMEPAGE_PORT=3004

# --- Pi-hole ---
# ⚠️  Genera la API key dall'interfaccia Pi-hole: Settings > API
HOMEPAGE_VAR_PIHOLE_URL=http://192.XXX.X.XX:8080
HOMEPAGE_VAR_PIHOLE_PASS=your_pihole_api_key_here

# --- Portainer ---
# ⚠️  Genera la API key da Portainer: Account > Access tokens
HOMEPAGE_VAR_PORTAINER_URL=https://192.XXX.X.XX:9443
HOMEPAGE_VAR_PORTAINER_IP_URL=https://192.XXX.X.XX:9443
HOMEPAGE_VAR_PORTAINER_API_KEY=your_portainer_api_key_here
HOMEPAGE_VAR_PORTAINER_ENV=3

# --- OpenWeatherMap ---
# ⚠️  Genera su: https://openweathermap.org/api
HOMEPAGE_VAR_OPENWEATHERMAP_KEY=your_openweathermap_api_key_here

# --- Jellyfin ---
# ⚠️  Genera da Jellyfin: Dashboard > API Keys
HOMEPAGE_VAR_JELLYFIN_API=your_jellyfin_api_key_here

# --- FileBrowser ---
HOMEPAGE_VAR_FILEBROWSER_URL=http://192.XXX.X.XX:8082
HOMEPAGE_VAR_FILEBROWSER_USER=your_filebrowser_username
HOMEPAGE_VAR_FILEBROWSER_PASS=your_filebrowser_password_here

# --- Uptime Kuma ---
HOMEPAGE_VAR_KUMA_URL=http://192.XXX.X.XX:3003
HOMEPAGE_VAR_KUMA_SLUG=status

# --- Grafana ---
HOMEPAGE_VAR_GRAFANA_USER=admin
HOMEPAGE_VAR_GRAFANA_PASS=your_grafana_password_here
