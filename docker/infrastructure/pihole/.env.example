# ============================================
#   PIHOLE — Environment Variables
#   Docs: https://github.com/pi-hole/docker-pi-hole
# ============================================

# --- Configurazione server ---
TZ=Europe/Rome

# --- Rete ---
# Indirizzo IP sull'interfaccia WireGuard
PIHOLE_IP_VPN=10.X.X.X
# Indirizzo IP sulla rete LAN
PIHOLE_IP_LAN=192.XXX.X.XX
# Porta per la web UI
PIHOLE_PORT_HTTP=8080

# --- Sicurezza ---
# Password per accedere alla web UI di Pi-hole
# ⚠️  Genera una password sicura con: openssl rand -base64 24
PIHOLE_ADMIN_PASSWORD='your_passwd'

# --- Integrazioni ---
# API key per il collegamento con Homepage (o altri servizi)
# ⚠️  Genera dalla web UI di Pi-hole: Settings → API
HOMEPAGE_VAR_PIHOLE_KEY=your_private_key
